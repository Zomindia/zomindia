    "@tailwindcss/vite": "^4.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.0",
    "canvas-confetti": "^1.9.4",
