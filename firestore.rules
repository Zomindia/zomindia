rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if user is in admins collection or has the specific email
      return isSignedIn() && request.auth.token.email_verified == true && (
               exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
               (request.auth.token.email == 'sarthakwebtech@gmail.com')
             );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role']) &&
             data.keys().size() >= 4 &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.email is string &&
             data.role in ['customer', 'partner', 'admin'] &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('notificationPreferences' in data) || (data.notificationPreferences is map)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.icon is string && data.icon.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('order' in data) || (data.order is number));
    }

    function isValidService(data) {
      return data.keys().hasAll(['categoryId', 'name', 'basePrice']) &&
             data.categoryId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.basePrice is number && data.basePrice >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('duration' in data) || (data.duration is string && data.duration.size() <= 200)) &&
             (!('imageURL' in data) || (data.imageURL is string && data.imageURL.size() <= 1000)) &&
             (!('priceListPDF' in data) || (data.priceListPDF is string && data.priceListPDF.size() <= 1000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('reviewCount' in data) || (data.reviewCount is number));
    }

    function isValidPartner(data) {
      return data.keys().hasAll(['userId', 'categories', 'status']) &&
             data.userId == request.auth.uid &&
             data.categories is list &&
             data.status in ['active', 'inactive', 'pending'] &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('reviewCount' in data) || (data.reviewCount is number)) &&
             (!('isVerified' in data) || (data.isVerified is bool)) &&
             (!('availabilityStatus' in data) || (data.availabilityStatus is string)) &&
             (!('lat' in data) || (data.lat is number)) &&
             (!('lng' in data) || (data.lng is number)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['customerId', 'serviceId', 'status', 'scheduledAt', 'address', 'totalPrice', 'paymentStatus']) &&
             data.status is string &&
             data.paymentStatus is string &&
             data.totalPrice is number &&
             data.scheduledAt is timestamp && 
             (!('partnerId' in data) || (data.partnerId is string || data.partnerId == null)) &&
             (!('serviceOtp' in data) || (data.serviceOtp is string)) &&
             (!('otpVerified' in data) || (data.otpVerified is bool)) &&
             (!('promoCode' in data) || (data.promoCode is string || data.promoCode == null)) &&
             (!('discountApplied' in data) || (data.discountApplied is number)) &&
             (!('cancellationReason' in data) || (data.cancellationReason is string && data.cancellationReason.size() <= 1000)) &&
             (!('pendingReason' in data) || (data.pendingReason is string || data.pendingReason == null)) &&
             (!('pendingResolveDate' in data) || (data.pendingResolveDate is timestamp || data.pendingResolveDate == null)) &&
             (!('pendingResolveDuration' in data) || (data.pendingResolveDuration is string || data.pendingResolveDuration == null)) &&
             (!('previousStatus' in data) || (data.previousStatus is string || data.previousStatus == null)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'customerId', 'partnerId', 'rating']) &&
             data.customerId == request.auth.uid &&
             data.rating is number &&
             (!('serviceId' in data) || (data.serviceId is string)) &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 1000)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidPromotion(data) {
      return data.keys().hasAll(['name', 'code', 'discountType', 'discountValue', 'active']) &&
             data.name is string &&
             data.code is string &&
             data.discountType in ['percent', 'flat'] &&
             data.discountValue is number &&
             data.active is bool &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('usageCount' in data) || (data.usageCount is number)) &&
             (!('expiryDate' in data) || (data.expiryDate is string || data.expiryDate is timestamp || data.expiryDate == null)) &&
             (!('applicableCategoryId' in data) || (data.applicableCategoryId is string || data.applicableCategoryId == null)) &&
             (!('applicableServiceId' in data) || (data.applicableServiceId is string || data.applicableServiceId == null)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidFAQ(data) {
      return data.keys().hasAll(['question', 'answer', 'category', 'isPublished']) &&
             data.question is string && data.question.size() > 0 &&
             data.answer is string && data.answer.size() > 0 &&
             data.category is string &&
             data.isPublished is bool &&
             (!('order' in data) || (data.order is number)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['userId', 'subject', 'message', 'status', 'priority']) &&
             data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.status in ['open', 'in_progress', 'resolved', 'closed'] &&
             data.priority in ['low', 'medium', 'high'] &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.read is bool &&
             data.createdAt is timestamp &&
             (!('type' in data) || (data.type is string)) &&
             (!('bookingId' in data) || (data.bookingId is string));
    }

    function isValidRedemption(data) {
      return data.keys().hasAll(['userId', 'promotionId', 'redeemedAt', 'status']) &&
             data.userId == request.auth.uid &&
             data.promotionId is string &&
             data.redeemedAt is timestamp &&
             data.status in ['active', 'used'] &&
             (!('appliedCategoryId' in data) || (data.appliedCategoryId is string)) &&
             (!('appliedServiceId' in data) || (data.appliedServiceId is string)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string &&
             data.createdAt is timestamp;
    }

    function isValidEarningsHistory(data) {
      return data.keys().hasAll(['type', 'createdAt']) &&
             data.type in ['booking_earning', 'reward_credit', 'adjustment'] &&
             (!('amount' in data) || (data.amount is number)) &&
             (!('credits' in data) || (data.credits is number)) &&
             (!('reason' in data) || (data.reason is string)) &&
             (!('bookingId' in data) || (data.bookingId is string)) &&
             data.createdAt is timestamp;
    }

    // --- RULES ---

    match /users/{userId} {
      allow get: if isSignedIn() || (resource.data.role == 'partner');
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
          isValidUser(incoming()) && 
          incoming().uid == existing().uid &&
          (
            // Regular profile update
            incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'photoURL', 'address', 'bio', 'notificationPreferences', 'updatedAt']) ||
            // Specific action: Sign up as admin or partner
            incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt'])
          )
        )
      );
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidPartner(incoming());
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin()) &&
                    (isAdmin() || (isValidPartner(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['categories', 'status', 'bio', 'lat', 'lng', 'updatedAt', 'availabilityStatus'])));

      match /earningsHistory/{historyId} {
        allow read: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/partners/$(partnerId)).data.userId) || isAdmin());
        allow create, update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && isValidId(bookingId) && (isOwner(existing().customerId) || isOwner(existing().partnerId) || isAdmin());
      allow list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid || 
        resource.data.partnerId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && exists(/databases/$(database)/documents/services/$(incoming().serviceId));
      allow update: if isSignedIn() && isValidId(bookingId) && (
        // Customer can cancel, pay, or finalize
        (isOwner(existing().customerId) && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['cancelled', 'finalized']) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'razorpayPaymentId', 'razorpayOrderId', 'razorpaySignature', 'status', 'updatedAt']) && incoming().paymentStatus == 'paid') ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'paymentIntentId', 'updatedAt']) && incoming().paymentStatus == 'paid')
        )) ||
        // Partner can update status or cancel with reason
        (isOwner(existing().partnerId) && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['confirmed', 'on_the_way', 'arrived', 'completed', 'finalized']) ||
          // OTP Verification Step
          (incoming().status == 'in_progress' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'otpVerified', 'updatedAt']) && 
           incoming().otpVerified == true &&
           get(/databases/$(database)/documents/bookings/$(bookingId)/secrets/otp).data.code != null) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'cancellationReason', 'updatedAt']) && incoming().status == 'cancelled') ||
          // Action: Manual Management / Pending / Reactivate / Reject
          (
            isValidBooking(incoming()) &&
            incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt', 'pendingReason', 'pendingResolveDate', 'pendingResolveDuration', 'previousStatus', 'partnerId']) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'pendingReason', 'pendingResolveDate', 'pendingResolveDuration', 'previousStatus', 'partnerId'])
          )
        )) ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.partnerId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.partnerId == request.auth.uid
        ) && isValidMessage(incoming());
      }

      match /secrets/otp {
        allow read: if isSignedIn() && isValidId(bookingId) && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
          isAdmin()
        );
        allow create, update, delete: if isAdmin();
      }

      match /otps/{code} {
        // Partner can verify by trying to 'get' a specific code. 
        // They CANNOT 'list' (see 'allow list: if ... isAdmin()')
        allow get: if isSignedIn() && isValidId(bookingId) && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.partnerId == request.auth.uid ||
          isAdmin()
        );
        allow list: if isSignedIn() && isValidId(bookingId) && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.customerId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isAdmin();
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming()) &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.customerId == request.auth.uid &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.status == 'completed';
      allow delete: if isAdmin() && isValidId(reviewId);
    }
    
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTicket(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /redemptions/{redemptionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidRedemption(incoming());
      allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin()) &&
                    (isAdmin() || (incoming().status == 'used' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])));
      allow delete: if isAdmin();
    }
    
    // Explicitly allow admins collection for the bootstrap check
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(adminId);
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
