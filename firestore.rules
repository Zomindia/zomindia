rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email.lower() == 'system-worker@zomindia.com') ||
        ('email_address' in request.auth.token && request.auth.token.email_address.lower() == 'system-worker@zomindia.com')
      );
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking original context structure
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if user has the specific master admin email or is verified and in admins collection or has admin role in profile
      return isSignedIn() && (
               ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'sarthakwebtech@gmail.com') ||
               ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email.lower() == 'sarthak.webtech@gmail.com') ||
               ('email_address' in request.auth.token && request.auth.token.email_address != null && request.auth.token.email_address.lower() == 'sarthakwebtech@gmail.com') ||
               ('email_address' in request.auth.token && request.auth.token.email_address != null && request.auth.token.email_address.lower() == 'sarthak.webtech@gmail.com') ||
               request.auth.uid == 'tAXPSenVwVgJRAJs2EcJN0UUzPI2' ||
               exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                'email' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email != null &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower() == 'sarthakwebtech@gmail.com') ||
               (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                'email' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email != null &&
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email.lower() == 'sarthak.webtech@gmail.com')
             );
    }

    function isHeadAdmin() {
      return isAdmin() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('adminSubRole' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminSubRole == 'head'
      );
    }

    function isAccountsAdmin() {
      return isAdmin() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('adminSubRole' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminSubRole == 'accounts' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminSubRole == 'head'
      );
    }

    function isHRAdmin() {
      return isAdmin() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('adminSubRole' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminSubRole == 'hr' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminSubRole == 'head'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role']) &&
             data.keys().size() >= 3 &&
             (data.uid == request.auth.uid || data.uid.startsWith('booking_sim_pro_') || isAdmin() || isHRAdmin() || isHeadAdmin()) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 100)) &&
             (!('email' in data) || data.email is string || data.email == null) &&
             data.role in ['customer', 'partner', 'admin'] &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('walletBalance' in data) || (data.walletBalance is number)) &&
             (!('notificationPreferences' in data) || (data.notificationPreferences is map)) &&
             (!('gender' in data) || (data.gender is string || data.gender == null)) &&
             (!('languagePreference' in data) || (data.languagePreference is string || data.languagePreference == null)) &&
             (!('houseType' in data) || (data.houseType is string || data.houseType == null)) &&
             (!('bhkSize' in data) || (data.bhkSize is string || data.bhkSize == null)) &&
             (!('preferredTimeSlot' in data) || (data.preferredTimeSlot is string || data.preferredTimeSlot == null)) &&
             (!('secondaryPhone' in data) || (data.secondaryPhone is string || data.secondaryPhone == null)) &&
             (!('phoneNumberVerified' in data) || (data.phoneNumberVerified is bool)) &&
             (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() <= 50)) &&
             (!('onboardingComplete' in data) || (data.onboardingComplete is bool)) &&
             (!('adminSubRole' in data) || (data.adminSubRole is string && data.adminSubRole in ['head', 'accounts', 'hr'])) &&
             (!('currentMode' in data) || (data.currentMode is string && data.currentMode in ['customer', 'partner'])) &&
             (!('customerData' in data) || (data.customerData is map)) &&
             (!('partnerData' in data) || (data.partnerData is map)) &&
             (!('isPartner' in data) || (data.isPartner is bool)) &&
             (!('partnerApplicationStatus' in data) || (data.partnerApplicationStatus is string)) &&
             (!('partnerId' in data) || (data.partnerId is string)) &&
             (!('city' in data) || (data.city is string)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt is string)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt is string));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'icon']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.icon is string && data.icon.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('order' in data) || (data.order is number));
    }

    function isValidService(data) {
      return data.keys().hasAll(['categoryId', 'name', 'basePrice']) &&
             data.categoryId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.basePrice is number && data.basePrice >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('duration' in data) || (data.duration is string && data.duration.size() <= 200)) &&
             (!('imageURL' in data) || (data.imageURL is string && data.imageURL.size() <= 1000)) &&
             (!('priceListPDF' in data) || (data.priceListPDF is string && data.priceListPDF.size() <= 1000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('reviewCount' in data) || (data.reviewCount is number));
    }

    function isValidPartner(data) {
      return data.keys().hasAll(['userId', 'categories', 'status']) &&
             (data.userId == request.auth.uid || data.userId.startsWith('booking_sim_pro_') || isAdmin() || isHRAdmin() || isHeadAdmin()) &&
             data.categories is list &&
             data.status in ['active', 'inactive', 'pending'] &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('reviewCount' in data) || (data.reviewCount is number)) &&
             (!('isVerified' in data) || (data.isVerified is bool)) &&
             (!('kycStatus' in data) || (data.kycStatus is string)) &&
             (!('kycDocuments' in data) || (data.kycDocuments is list)) &&
             (!('availabilityStatus' in data) || (data.availabilityStatus is string)) &&
             (!('totalEarnings' in data) || (data.totalEarnings is number)) &&
             (!('rewardCredits' in data) || (data.rewardCredits is number)) &&
             (!('lat' in data) || (data.lat is number)) &&
             (!('lng' in data) || (data.lng is number)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['customerUid', 'serviceId', 'status', 'scheduledAt', 'address', 'totalPrice', 'paymentStatus']) &&
             data.status is string &&
             data.paymentStatus is string &&
             data.totalPrice is number &&
             data.scheduledAt is timestamp && 
             (!('partnerId' in data) || (data.partnerId is string || data.partnerId == null)) &&
             (!('lat' in data) || (data.lat is number || data.lat == null)) &&
             (!('lng' in data) || (data.lng is number || data.lng == null)) &&
             (!('serviceOtp' in data) || (data.serviceOtp is string && data.serviceOtp.size() == 4)) &&
             (!('otpVerified' in data) || (data.otpVerified is bool)) &&
             (!('progressPercentage' in data) || (data.progressPercentage is number)) &&
             (!('checklist' in data) || (data.checklist is list)) &&
             (!('startOTP' in data) || (data.startOTP is string)) &&
             (!('partnerLocation' in data) || (data.partnerLocation is map)) &&
             (!('promoCode' in data) || (data.promoCode is string || data.promoCode == null)) &&
             (!('discountApplied' in data) || (data.discountApplied is number)) &&
             (!('cancellationReason' in data) || (data.cancellationReason is string && data.cancellationReason.size() <= 1000)) &&
             (!('pendingReason' in data) || (data.pendingReason is string || data.pendingReason == null)) &&
             (!('pendingResolveDate' in data) || (data.pendingResolveDate is timestamp || data.pendingResolveDate == null)) &&
             (!('pendingResolveDuration' in data) || (data.pendingResolveDuration is string || data.pendingResolveDuration == null)) &&
             (!('previousStatus' in data) || (data.previousStatus is string || data.previousStatus == null)) &&
             (!('completedTasks' in data) || (data.completedTasks is list)) &&
             (!('completionPhotos' in data) || (data.completionPhotos is list)) &&
             (!('paymentMethod' in data) || (data.paymentMethod is string || data.paymentMethod == null)) &&
             (!('isAmcBooking' in data) || (data.isAmcBooking is bool)) &&
             (!('amcId' in data) || (data.amcId is string || data.amcId == null)) &&
             (!('customerBookedEmail' in data) || (data.customerBookedEmail is string || data.customerBookedEmail == null)) &&
             (!('customerBookedPhone' in data) || (data.customerBookedPhone is string || data.customerBookedPhone == null)) &&
             (!('additionalCharges' in data) || (data.additionalCharges is list)) &&
             (!('activeCall' in data) || (data.activeCall is map || data.activeCall == null)) &&
             (!('secondaryContact' in data) || (data.secondaryContact is string || data.secondaryContact == null)) &&
             (!('completionNote' in data) || (data.completionNote is string || data.completionNote == null)) &&
             (!('completedAt' in data) || (data.completedAt is timestamp || data.completedAt == null)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'customerUid', 'partnerId', 'rating']) &&
             data.customerUid == request.auth.uid &&
             data.rating is number &&
             (!('serviceId' in data) || (data.serviceId is string)) &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 1000)) &&
             (!('ratingDetails' in data) || (data.ratingDetails is map)) &&
             (!('photoURL' in data) || (data.photoURL is string)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidPromotion(data) {
      return data.name is string && data.name.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             data.discountType in ['percent', 'flat'] &&
             data.discountValue is number &&
             data.active is bool &&
             (!('usageCount' in data) || data.usageCount is number) &&
             (!('usageLimit' in data) || data.usageLimit is number);
    }

    // Checking remaining validators
    function isValidFAQ(data) {
      return data.keys().hasAll(['question', 'answer', 'category', 'isPublished']) &&
             data.question is string && data.question.size() > 0 &&
             data.answer is string && data.answer.size() > 0 &&
             data.category is string &&
             data.isPublished is bool &&
             (!('order' in data) || (data.order is number)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp));
    }

    function isValidTicket(data) {
      return data.keys().hasAll(['userId', 'subject', 'message', 'status', 'priority']) &&
             data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.status in ['open', 'in_progress', 'resolved', 'closed'] &&
             data.priority in ['low', 'medium', 'high'] &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000 &&
             data.read is bool &&
             data.createdAt is timestamp &&
             (!('type' in data) || (data.type is string)) &&
             (!('bookingId' in data) || (data.bookingId is string || data.bookingId == null));
    }

    function isValidRedemption(data) {
      return data.keys().hasAll(['userId', 'promotionId', 'redeemedAt', 'status']) &&
             data.userId == request.auth.uid &&
             data.promotionId is string &&
             data.redeemedAt is timestamp &&
             data.status in ['active', 'used'] &&
             (!('appliedCategoryId' in data) || (data.appliedCategoryId is string)) &&
             (!('appliedServiceId' in data) || (data.appliedServiceId is string)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    function isValidEarningsHistory(data) {
      return data.keys().hasAll(['type', 'createdAt']) &&
             data.type in ['booking_earning', 'reward_credit', 'adjustment'] &&
             (!('amount' in data) || (data.amount is number)) &&
             (!('credits' in data) || (data.credits is number)) &&
             (!('reason' in data) || (data.reason is string && data.reason.size() <= 1000)) &&
             (!('bookingId' in data) || (data.bookingId is string)) &&
             data.createdAt is timestamp;
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['adminId', 'action', 'createdAt']) &&
             data.adminId == request.auth.uid &&
             data.action is string &&
             (!('targetId' in data) || (data.targetId is string)) &&
             (!('details' in data) || (data.details is string)) &&
             data.createdAt is timestamp;
    }

    function isValidWalletTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'reason', 'status', 'createdAt']) &&
             data.userId is string &&
             data.amount is number &&
             data.type in ['credit', 'debit'] &&
             data.reason is string &&
             data.status in ['pending', 'completed', 'failed'] &&
             (!('referenceId' in data) || data.referenceId is string) &&
             data.createdAt is timestamp;
    }

    function isValidPayoutRequest(data) {
      return data.keys().hasAll(['partnerId', 'amount', 'status', 'createdAt']) &&
             data.partnerId is string &&
             data.amount is number &&
             data.status in ['pending', 'processed', 'completed', 'failed'] &&
             (!('processedAt' in data) || data.processedAt is timestamp) &&
             data.createdAt is timestamp;
    }

    function isValidAMC(data) {
      return data.keys().hasAll(['customerId', 'serviceId', 'planName', 'frequency', 'startDate', 'endDate', 'totalPrice', 'status', 'leadSource']) &&
             data.status in ['active', 'expired', 'pending_renewal', 'cancelled', 'pending_payment'] &&
             data.leadSource in ['customer_direct', 'partner_lead', 'admin_manual'] &&
             data.frequency is number &&
             data.totalPrice is number &&
             (!('partnerId' in data) || (data.partnerId is string || data.partnerId == null)) &&
             (!('partnerCommission' in data) || (data.partnerCommission is number)) &&
             (!('serviceBookingIds' in data) || (data.serviceBookingIds is list)) &&
             (!('scheduledDates' in data) || (data.scheduledDates is list)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    // --- RULES ---

    match /amcs/{amcId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && (resource.data.customerId == request.auth.uid || (("partnerId" in resource.data) && resource.data.partnerId == request.auth.uid))));
      allow list: if isSignedIn() && (isAdmin() || resource.data.customerId == request.auth.uid || (("partnerId" in resource.data) && resource.data.partnerId == request.auth.uid));
      allow create: if isSignedIn() && (isAdmin() || incoming().customerId == request.auth.uid) && isValidAMC(incoming());
      allow update: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || isOwner(existing().customerId) || isOwner(existing().partnerId)) && (
        isHeadAdmin() || isAccountsAdmin() || (
          // Allow customer or partner to update booking history or status
          incoming().diff(existing()).affectedKeys().hasAny(['serviceBookingIds', 'status', 'updatedAt']) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['serviceBookingIds', 'status', 'updatedAt'])
        )
      );
      allow delete: if isAdmin();
    }

    match /walletTransactions/{transactionId} {
      allow read: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow list: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || incoming().userId == request.auth.uid) && isValidWalletTransaction(incoming());
      allow update: if isSignedIn() && isAccountsAdmin() && (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /payoutRequests/{requestId} {
      allow read: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || isHRAdmin() || (resource != null && resource.data.partnerId == request.auth.uid));
      allow list: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || isHRAdmin() || resource.data.partnerId == request.auth.uid);
      allow create: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || incoming().partnerId == request.auth.uid) && isValidPayoutRequest(incoming());
      allow update: if isSignedIn() && (isAccountsAdmin() || isHeadAdmin() || isHRAdmin()) && (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'processedAt', 'completedAt', 'failedAt']));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() || (resource != null && resource.data.get('role', '') == 'partner');
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(userId) || userId.startsWith('booking_sim_pro_') || isAdmin() || isHRAdmin() || isHeadAdmin()) && isValidUser(incoming());
      allow update: if isSignedIn() && (isOwner(userId) || userId.startsWith('booking_sim_pro_') || isHRAdmin() || isHeadAdmin() || isAdmin()) && (
        isHeadAdmin() || isHRAdmin() || isAdmin() || isOwner(userId) || (
          isValidUser(incoming()) && 
          incoming().uid == existing().uid &&
          (
            // Allowed completely for simulated partner users
            userId.startsWith('booking_sim_pro_') ||
            // Regular user profile update
            ((isOwner(userId)) && (
              (incoming().diff(existing()).affectedKeys().hasOnly([
                'displayName', 'fullName', 'email', 'phoneNumber', 'phoneNumberVerified', 'photoURL', 'address', 'bio', 
                'notificationPreferences', 'updatedAt', 'gender', 'languagePreference', 
                'houseType', 'bhkSize', 'preferredTimeSlot', 'secondaryPhone', 'onboardingComplete',
                'currentMode', 'customerData', 'partnerData', 'isPartner'
              ])) ||
              ('email' in request.auth.token && request.auth.token.email.lower() == 'sarthakwebtech@gmail.com') ||
              ('email_address' in request.auth.token && request.auth.token.email_address.lower() == 'sarthakwebtech@gmail.com') ||
              ('email' in existing() && existing().email != null && existing().email.lower() == 'sarthakwebtech@gmail.com') ||
              ('email' in existing() && existing().email != null && existing().email.lower() == 'sarthak.webtech@gmail.com') ||
              userId == 'tAXPSenVwVgJRAJs2EcJN0UUzPI2'
            )) ||
            // Partner onboarding (HR can verify, but user can opt-in)
            (isHRAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'updatedAt'])) ||
            // Role assignment (Head Admin only)
            (isHeadAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['role', 'adminSubRole', 'updatedAt']))
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isHeadAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isHeadAdmin();
      allow update: if isSignedIn() && (
        isHeadAdmin() || (
          // Allow customer/partner to submit rating/review updates
          incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'reviewCount']) &&
          incoming().reviewCount == existing().get('reviewCount', 0) + 1 &&
          incoming().rating is number && incoming().rating >= 0 && incoming().rating <= 5
        )
      );
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow create: if isSignedIn() && (isAdmin() || isHRAdmin() || isHeadAdmin() || incoming().userId == request.auth.uid);
      allow update: if isSignedIn() && (
        isAdmin() || isHRAdmin() || isHeadAdmin() || (
          isOwner(existing().userId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['availabilityStatus', 'isAvailable', 'fcmToken', 'lat', 'lng', 'partnerLocation', 'updatedAt'])
        )
      );
      allow delete: if isAdmin();

      match /earningsHistory/{historyId} {
        allow read: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || isOwner(get(/databases/$(database)/documents/partners/$(partnerId)).data.userId));
        allow create: if isSignedIn() && (isHeadAdmin() || isAccountsAdmin() || isOwner(get(/databases/$(database)/documents/partners/$(partnerId)).data.userId));
        allow update: if isAccountsAdmin() || isHeadAdmin();
        allow delete: if isHeadAdmin();
      }
    }

    match /promotions/{promoId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPromotion(incoming());
      allow update: if (isAdmin() && isValidPromotion(incoming())) || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['usageCount', 'updatedAt']) &&
        incoming().usageCount == (existing().get('usageCount', 0) + 1)
      );
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && isValidId(bookingId) && (
        isAdmin() || 
        (resource != null && (
          resource.data.get('customerUid', '') == request.auth.uid ||
          resource.data.get('partnerId', '') == request.auth.uid
        ))
      );
      allow list: if isSignedIn() && (
        isAdmin() ||
        resource.data.get('customerUid', '') == request.auth.uid || 
        resource.data.get('partnerId', '') == request.auth.uid || 
        resource.data.get('status', '') == "pending" ||
        (resource.data.get('status', '') != "cancelled" && resource.data.get('status', '') != "rejected")
      );
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && (
        incoming().get('customerUid', '') == request.auth.uid
      ) && (
        exists(/databases/$(database)/documents/services/$(incoming().serviceId)) || 
        !exists(/databases/$(database)/documents/services/$(incoming().serviceId))
      );
      allow update: if isSignedIn() && isValidId(bookingId) && (
        // Customer update branch
        (existing().get('customerUid', '') == request.auth.uid && (
          // Action: Cancel or Finalize
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status in ['cancelled', 'finalized']) ||
          // Action: Pay Online
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'razorpayPaymentId', 'razorpayOrderId', 'razorpaySignature', 'status', 'updatedAt']) && incoming().paymentStatus == 'paid') ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'paymentIntentId', 'updatedAt']) && incoming().paymentStatus == 'paid') ||
          // Action: Pay with Cash (Customer confirming cash handover)
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'paymentMethod', 'updatedAt']) && incoming().status == 'completed' && incoming().paymentStatus == 'paid' && incoming().paymentMethod == 'cash') ||
          // Action: Reschedule
          (incoming().diff(existing()).affectedKeys().hasOnly(['scheduledAt', 'status', 'partnerId', 'activeCall', 'updatedAt']) && incoming().status == 'pending') ||
          // Action: Chat Quick Action (Secondary Contact)
          (incoming().diff(existing()).affectedKeys().hasOnly(['secondaryContact', 'updatedAt'])) ||
          // Action: Active Call status
          (incoming().diff(existing()).affectedKeys().hasOnly(['activeCall', 'updatedAt']))
        )) ||
        // Partner assignment/claim branch
        (
          existing().get('status', '') == 'pending' &&
          (!('partnerId' in existing()) || existing().partnerId == null || existing().partnerId == '') &&
          incoming().partnerId == request.auth.uid &&
          incoming().status == 'assigned' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'partnerId', 'updatedAt'])
        ) ||
        // Partner update branch
        (existing().get('partnerId', '') == request.auth.uid && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'status', 'otpVerified', 'cancellationReason', 'completedTasks', 'completionPhotos',
            'pendingReason', 'pendingResolveDate', 'pendingResolveDuration', 
            'previousStatus', 'partnerId', 'additionalCharges', 'totalPrice', 
            'paymentStatus', 'paymentMethod', 'secondaryContact', 'completionNote', 'lat', 'lng', 'address', 'updatedAt', 'activeCall', 'partnerLocation', 'completedAt'
          ])
        )) ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && isValidId(bookingId) && (
          isAdmin() ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('customerUid', '') == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('partnerId', '') == request.auth.uid
        );
        allow create: if isSignedIn() && isValidId(bookingId) && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('customerUid', '') == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('partnerId', '') == request.auth.uid
        ) && isValidMessage(incoming());
      }

      match /secrets/otp {
        allow read: if isSignedIn() && isValidId(bookingId) && (
          isAdmin() ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('customerUid', '') == request.auth.uid
        );
        allow create: if isSignedIn() && isValidId(bookingId);
        allow update, delete: if isAdmin();
      }

      match /otps/{code} {
        // Partner can verify by trying to 'get' a specific code. 
        // They CANNOT 'list' (see 'allow list: if ... isAdmin()')
        allow get: if isSignedIn() && isValidId(bookingId) && (
          isAdmin() ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('customerUid', '') == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('partnerId', '') == request.auth.uid
        );
        allow list: if isSignedIn() && isValidId(bookingId) && (
          isAdmin() ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.get('customerUid', '') == request.auth.uid
        );
        allow create: if isAdmin();
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming()) &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.get('customerUid', '') == request.auth.uid &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.get('status', '') in ['completed', 'payment_pending', 'finalized'];
      allow delete: if isAdmin() && isValidId(reviewId);
    }

    match /whatsapp_alerts/{alertId} {
      allow read, write: if isSignedIn();
    }
    
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidTicket(incoming());
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isHeadAdmin() || isHRAdmin();
      allow create: if isAdmin() && isValidAuditLog(incoming());
      allow delete: if isAdmin();
    }

    match /redemptions/{redemptionId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidRedemption(incoming());
      allow update: if isSignedIn() && (isAdmin() || (isOwner(resource.data.userId) &&
                     incoming().status == 'used' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])));
      allow delete: if isAdmin();
    }

    function isValidCityDemand(data) {
      return data.keys().hasAll(['user_id', 'current_logged_in_name', 'target_city', 'target_state', 'clicked_timestamp']) &&
             data.keys().size() == 5 &&
             data.user_id is string &&
             data.current_logged_in_name is string &&
             data.target_city is string &&
             data.target_state is string &&
             data.clicked_timestamp != null;
    }

    match /cityDemandAnalytics/{analyticsId} {
      allow read: if isAdmin();
      allow list: if isAdmin();
      allow create: if isValidCityDemand(incoming());
      allow update, delete: if isAdmin();
    }
    
    // Explicitly allow admins collection for the bootstrap check
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(adminId);
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    match /system_updates/{updateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    function isValidPartnerApplication(data) {
      return data.keys().hasAll(['fullName', 'phone', 'serviceType', 'area', 'createdAt']) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.phone is string && data.phone.size() > 0 &&
             data.serviceType is string && data.serviceType.size() > 0 &&
             data.area is string && data.area.size() > 0;
    }

    match /partner_applications/{applicationId} {
      allow read, write: if true;
    }

    match /partnerApplications/{applicationId} {
      allow read, write: if true;
    }
  }
}
